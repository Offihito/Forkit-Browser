{
  "name": "forkit",
  "version": "1.3.0",
  "description": "Open Source Browser Based on Chromium",
  "main": "Files/index.html",
  "homepage": "./",
  "scripts": {
    "start": "nw .",
    "start:sdk": "nw --remote-debugging-port=9222 ."
  },
  "keywords": [
    "browser",
    "nwjs",
    "chromium",
    "open-source"
  ],
  "author": {
    "name": "Offihito",
    "email": "offihito@example.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "window": {
    "title": "Forkit Browser",
    "width": 1400,
    "height": 800,
    "frame": false,
    "icon": "build/icon.png"
  },
  "chromium-args": "--disable-blink-features=AutomationControlled --enable-features=EncryptedClientHello --proxy-server=http://127.0.0.1:7676",
  "node-remote": "<all_urls>",
  "bg-script": "bg-script.js",
  "permissions": [
    "webview",
    "clipboardRead",
    "clipboardWrite"
  ],
  "devDependencies": {
    "nw": "^0.107.0"
  },
  "dependencies": {
    "@ghostery/adblocker": "^2.14.1",
    "@ghostery/adblocker-electron": "^2.14.1",
    "cross-fetch": "^4.1.0",
    "fs-extra": "^11.3.4"
  }
}
